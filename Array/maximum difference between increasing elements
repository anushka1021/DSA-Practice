#LEETCODE 2016 
#Maximum_Difference_Between_Increasing_Elements
#find_difference_btw_i_and_j_where_j_is_greater_than_i

class Solution:
    def maximumDifference(self, nums: List[int]) -> int:
        n=len(nums)
        i=0
        max_diff=-1
        for j in range(1,n):
            if nums[j]>nums[i]:
                max_diff = max(max_diff,nums[j]-nums[i])

            if nums[j]<nums[i]:
                i=j 

        return max_diff
